# Example .env for local Postgres
# Copy to .env and update values for your environment.

# Example Postgres connection for local development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dr2_community"

# Alternatively, you can provide connection pieces using the KK_* vars below.
# The app will construct the full DATABASE_URL from these if DATABASE_URL is unset.
# Example (Postgres):
# KK_HOST=localhost
# KK_PORT=5432
# KK_USERNAME=postgres
# KK_PASSWORD=postgres
# KK_DATABASE=dr2_community
# KK_SSL=false
# SCHEME=desarestu_db

# Application secret (preferred):
SECRET_KEY="replace-with-a-long-random-secret"

# Legacy/auth secret fallback (optional):
AUTH_SECRET="replace-with-a-long-random-secret"
UPLOAD_DIR="./uploads"
UPLOAD_MAX_BYTES="5242880"
PUBLIC_FORM_RATE_LIMIT_WINDOW_SECONDS="300"
PUBLIC_FORM_RATE_LIMIT_MAX="5"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
# Set TURNSTILE_SECRET_KEY in your environment or CI secrets
TURNSTILE_SECRET_KEY=""

# Note: In production (Vercel), set `DATABASE_URL` to your managed Postgres
# provider (Supabase, Neon, AWS RDS, etc.). Do not use a file-based SQLite
# `DATABASE_URL` on serverless platforms as the filesystem is ephemeral.
UPLOAD_DIR="./uploads"
UPLOAD_MAX_BYTES="5242880"
PUBLIC_FORM_RATE_LIMIT_WINDOW_SECONDS="300"
PUBLIC_FORM_RATE_LIMIT_MAX="5"