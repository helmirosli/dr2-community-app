# Copy this file to .env and fill in the values.

# ── Database ──────────────────────────────────────────────────────────────────

# App connection (Transaction pooler, port 6543)
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# Backup / migration connection (Session pooler, port 5432 — not for app use)
DATABASE_URL_DIRECT="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ── Auth ──────────────────────────────────────────────────────────────────────

# Session signing secret (any long random string)
SECRET_KEY="replace-with-a-long-random-secret"
# AUTH_SECRET is accepted as a fallback alias for SECRET_KEY
# AUTH_SECRET=""

# ── Google Cloud Storage (file uploads + DB backups) ─────────────────────────

GCS_BUCKET_NAME="your-bucket-name"
GCS_PROJECT_ID="your-gcp-project-id"
GCS_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Public base URL for uploaded files
GCS_BASE_URL="https://storage.googleapis.com"
# Optional path prefix inside the bucket (leave empty for root)
GCS_BASE_PATH=""
# Set to "true" to serve uploaded files publicly
GCS_PUBLIC_FILES="true"

# ── DB Backup (GitHub Actions) ────────────────────────────────────────────────

# Service account JSON — used by the db:backup workflow.
# Store as GCS_SERVICE_ACCOUNT_JSON in GitHub Secrets (not needed locally).
# GCS_SERVICE_ACCOUNT_JSON=""

# Optional: override pg_dump binary path (defaults to system pg_dump)
# PG_DUMP_BIN="/opt/homebrew/opt/postgresql@17/bin/pg_dump"

# ── File uploads ──────────────────────────────────────────────────────────────

# Max upload size in bytes (default 5 MB)
UPLOAD_MAX_BYTES="5242880"

# ── Turnstile (bot protection on public form) ─────────────────────────────────

NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY=""

# ── Alternative DB connection (KK_* vars) ─────────────────────────────────────
# Use these instead of DATABASE_URL if your host provides individual credentials.
# KK_HOST=""
# KK_PORT="5432"
# KK_USERNAME=""
# KK_PASSWORD=""
# KK_DATABASE=""
# KK_SSL="true"
